# syntax=docker/dockerfile:1
#
# Image for the crond-agent mutating admission webhook (injector).
#
# Kept SEPARATE from the agent image (Dockerfile) on purpose: the agent binary
# is copied into every wrapped job pod via the init-container pattern, so it
# must stay tiny. The injector runs as a long-lived Deployment.
#
# COPY-only, mirroring Dockerfile: goreleaser (dockers_v2) builds the static
# binary and places each platform's copy under a TARGETPLATFORM-prefixed
# subdirectory of the build context. The kind e2e (scripts/e2e-injector.sh)
# stages the binary the same way so this one Dockerfile serves both paths.

# Pinned by digest — matches the agent Dockerfile so both images share one
# audited certs layer.
FROM alpine:3.24@sha256:28bd5fe8b56d1bd048e5babf5b10710ebe0bae67db86916198a6eec434943f8b AS certs
RUN apk add --no-cache ca-certificates

FROM scratch
ARG TARGETPLATFORM
COPY --from=certs /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY $TARGETPLATFORM/crond-agent-injector /crond-agent-injector
USER 65532:65532
ENTRYPOINT ["/crond-agent-injector"]
